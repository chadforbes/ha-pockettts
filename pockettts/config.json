{
  "name": "Pocket TTS",
  "slug": "pockettts",
  "description": "Local, lightweight CPU text-to-speech (Kyutai Pocket TTS via ONNX / sherpa-onnx).",
  "version": "1.3.0",
  "arch": [
    "aarch64",
    "amd64"
  ],
  "startup": "services",
  "boot": "auto",
  "init": false,
  "ingress": true,
  "ingress_port": 8000,
  "ingress_entry": "/",
  "panel_title": "Pocket TTS",
  "panel_icon": "mdi:microphone-message",
  "hassio_api": false,
  "homeassistant_api": false,
  "host_network": false,
  "map": [
    "share:ro",
    "media:ro"
  ],
  "ports": {
    "8000/tcp": 8000
  },
  "ports_description": {
    "8000/tcp": "Pocket TTS HTTP API \u2014 used by the Pocket TTS integration"
  },
  "options": {
    "num_steps": 8,
    "num_threads": 2,
    "voice": ""
  },
  "schema": {
    "num_steps": "int(1,50)",
    "num_threads": "int(1,16)",
    "voice": "str?"
  }
}
