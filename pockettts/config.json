{
  "name": "Pocket TTS",
  "slug": "pockettts",
  "description": "Local CPU text-to-speech (Kyutai Pocket TTS, full FP32 quality).",
  "version": "2.0.1",
  "arch": [
    "aarch64",
    "amd64"
  ],
  "startup": "services",
  "boot": "auto",
  "init": false,
  "ingress": true,
  "ingress_port": 8000,
  "ingress_entry": "/",
  "panel_title": "Pocket TTS",
  "panel_icon": "mdi:microphone-message",
  "hassio_api": false,
  "homeassistant_api": false,
  "host_network": false,
  "map": [
    "share:ro",
    "media:ro"
  ],
  "ports": {
    "8000/tcp": 8000
  },
  "ports_description": {
    "8000/tcp": "Pocket TTS HTTP API \u2014 used by the Pocket TTS integration"
  },
  "options": {
    "language": "english",
    "temperature": 0.7,
    "eos_threshold": -4.0,
    "num_threads": 2,
    "voice": ""
  },
  "schema": {
    "language": "list(english|english_2026-01|french_24l|german_24l|portuguese_24l|italian_24l|spanish_24l)",
    "temperature": "float(0,2)",
    "eos_threshold": "float(-20,20)",
    "num_threads": "int(1,16)",
    "voice": "str?"
  }
}
